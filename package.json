{
  "name": "gradebee",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\"",
    "dev:frontend": "cd frontend && npm run dev",
    "dev:backend": "cd backend/cmd/server && go run .",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "prepare": "husky"
  },
  "devDependencies": {
    "@clerk/testing": "^2.0.4",
    "@playwright/test": "^1.58.2",
    "concurrently": "^9.1.2",
    "dotenv": "^17.3.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0"
  }
}
