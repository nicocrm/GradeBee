# Frontend env vars are in frontend/.env

# Backend
CLERK_SECRET_KEY=sk_live_xxx
OPENAI_API_KEY=sk-xxx
ALLOWED_ORIGIN=http://localhost:5173
DB_PATH=/data/gradebee.db

# Backend log level
LOG_LEVEL=DEBUG

# Deployment
DOMAIN=localhost
VPS_HOST=root@<your-vps-ip>

# VPS provisioning (optional overrides for scripts/provision-vps.sh)
# INSTANCE_TYPE=STARDUST1-S
# ZONE=fr-par-1
# Scaleway — credentials used by AWS CLI and Terraform
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# SCW_ACCESS_KEY=
# SCW_SECRET_KEY=
# SCW_DEFAULT_ORGANIZATION_ID=
# SCW_DEFAULT_PROJECT_ID=
