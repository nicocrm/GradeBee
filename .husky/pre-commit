# Frontend: TypeScript check (whole project, catches type errors)
cd frontend && npx tsc -b --noEmit || exit 1
cd ..

# Frontend: Lint & format staged files
npx lint-staged || exit 1

# Backend: Go lint (only if Go files are staged)
if git diff --cached --name-only | grep -q '\.go$'; then
  cd backend && make lint || exit 1
fi
